FROM python:3.11-slim

WORKDIR /app

COPY CLI/sawectl/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY CLI/sawectl /app/sawectl
COPY Engine/modules /app/modules
COPY Engine/workflows /app/workflows

RUN printf '%s\n' '#!/bin/sh' 'exec python3 /app/sawectl/sawectl.py "$@"' > /usr/local/bin/sawectl \
    && chmod +x /usr/local/bin/sawectl

ENTRYPOINT ["sawectl"]
CMD ["--help"]
